<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Sheyla Llivisaca</title>

<style>
body {
  margin: 0;
  overflow: hidden;
  font-family: Arial;
  text-align: center;
  background: #87ceeb;
}

/* Título */
h1 {
  margin-top: 15px;
  font-size: 28px;
}

/* Texto */
#distancia {
  margin-top: 10px;
  font-size: 24px;
  font-weight: bold;
}

#estado {
  font-size: 22px;
  margin-top: 5px;
  font-weight: bold;
}

/* Suelo */
.riel {
  position: absolute;
  bottom: 80px;
  width: 100%;
  height: 10px;
  background: #6d4c7d;
}

/* GATO */
.gato {
  position: absolute;
  bottom: 90px;
  left: 0;
  transition: left 0.5s linear;
}

/* Cuerpo */
.cuerpo {
  width: 120px;
  height: 50px;
  background: #ff9800;
  border-radius: 25px;
  position: relative;
}

/* Cabeza */
.cabeza {
  width: 50px;
  height: 50px;
  background: #ffb74d;
  position: absolute;
  left: 90px;
  top: -10px;
  border-radius: 50%;
}

/* Orejas */
.oreja {
  width: 0;
  height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-bottom: 20px solid #ff9800;
  position: absolute;
  top: -15px;
}

.o1 { left: 95px; }
.o2 { left: 115px; }

/* Ojos */
.ojo {
  width: 8px;
  height: 8px;
  background: black;
  border-radius: 50%;
  position: absolute;
  top: 15px;
}

.oj1 { left: 105px; }
.oj2 { left: 120px; }

/* Patas */
.pata {
  width: 15px;
  height: 20px;
  background: #e65100;
  position: absolute;
  bottom: -15px;
  border-radius: 5px;
}

.p1 { left: 10px; }
.p2 { left: 40px; }
.p3 { left: 70px; }

/* Animación */
@keyframes caminar {
  0% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
  100% { transform: translateY(0); }
}

.caminando {
  animation: caminar 0.4s infinite;
}
</style>
</head>

<body>

<h1>Sheyla Llivisaca</h1>

<div id="distancia">Distancia: 0 cm</div>
<div id="estado">Estado: Detenido</div>

<div class="riel"></div>

<div class="gato" id="gato">
  <div class="cuerpo"></div>
  <div class="cabeza"></div>

  <div class="oreja o1"></div>
  <div class="oreja o2"></div>

  <div class="ojo oj1"></div>
  <div class="ojo oj2"></div>

  <div class="pata p1"></div>
  <div class="pata p2"></div>
  <div class="pata p3"></div>
</div>

<script>
let gato = document.getElementById("gato");
let distanciaTexto = document.getElementById("distancia");
let estadoTexto = document.getElementById("estado");

// Simulación de distancia (puedes conectar tu sensor aquí)
setInterval(() => {
  let distancia = Math.floor(Math.random() * 100);

  distanciaTexto.innerHTML = "Distancia: " + distancia + " cm";

  if (distancia > 30) {
    gato.style.left = (distancia * 5) + "px";
    gato.classList.add("caminando");
    estadoTexto.innerHTML = "Estado: Avanzando 🐱";
  } else {
    gato.classList.remove("caminando");
    estadoTexto.innerHTML = "Estado: Detenido";
  }

}, 1000);
</script>

</body>
</html>
